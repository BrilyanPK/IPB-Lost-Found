# Gunakan URL PostgreSQL lokal atau Cloud (Supabase/Neon)
# Contoh Supabase: postgresql://postgres.[YOUR-PROJECT-ID]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.ktfrbgdvslwczgvihhqr.supabase.co:5432/postgres"
SECRET_KEY="supersecretkey_ganti_ini_nanti"
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase Storage (untuk upload foto)
# Gunakan service_role key (bukan anon key) karena upload dilakukan dari backend
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_KEY=[YOUR-SERVICE-ROLE-KEY]
SUPABASE_BUCKET=uploads